# Application Settings
VITE_APP_NAME=Joshy's Tour Planner
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION=Student Trip Enquiry & Live Cost Estimation System

# API Configuration
VITE_API_BASE_URL=http://localhost:3000
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_LOGGING=true
VITE_LOG_LEVEL=debug

# Rate Card Version
VITE_RATE_CARD_VERSION=2.0

# UI Configuration
VITE_DEFAULT_PORT=5173
VITE_AUTO_OPEN_BROWSER=true

# Profit Margin
VITE_PROFIT_MARGIN=0.20
